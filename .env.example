# ─────────────────────────────────────────────────────────────
# ROVE Hire — environment configuration
# Copy to `.env` for local dev; set the same keys in the Vercel dashboard.
# ─────────────────────────────────────────────────────────────

# Public base URL of the deployed app. Magic links are built from this,
# NEVER from the incoming request — set it correctly in production.
APP_URL="http://localhost:3000"

# PostgreSQL. DATABASE_URL is used by the app at runtime and MUST go through a
# connection pooler (PgBouncer) — on serverless (Vercel) many function instances
# each open their own pool, so a direct connection exhausts the server's slots
# ("too many clients"). DIRECT_URL is the unpooled connection used for migrations.
#
# Neon: use the *-pooler host for DATABASE_URL and the direct host for DIRECT_URL.
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/rovehire?sslmode=require&pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/rovehire?sslmode=require"
#
# Aiven: enable the built-in "Connection pooling" (PgBouncer, transaction mode)
# in the console — it exposes a SEPARATE pooler port. Point DATABASE_URL at the
# POOLER port and DIRECT_URL at the raw Postgres port (e.g. :22126). Do NOT point
# DATABASE_URL at the raw port on Vercel.
# DATABASE_URL="postgresql://avnadmin:pass@pg-xxx.aivencloud.com:POOLER_PORT/defaultdb?sslmode=require&pgbouncer=true&connection_limit=1"
# DIRECT_URL="postgresql://avnadmin:pass@pg-xxx.aivencloud.com:22126/defaultdb?sslmode=require"

# Session cookie signing / hashing pepper (32+ random bytes, base64). Rotate to invalidate all sessions.
SESSION_SECRET="change-me-generate-with-openssl-rand-base64-32"

# AWS S3 (private bucket) for resumes + generated PDFs.
AWS_REGION="ap-south-1"
AWS_ACCESS_KEY_ID="AKIA..."
AWS_SECRET_ACCESS_KEY="..."
S3_BUCKET="rove-hire-files"

# Seed-only: password assigned to the seeded HR test account.
SEED_HR_PASSWORD="rovehire-demo-2026"
